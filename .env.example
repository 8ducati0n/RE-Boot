# --- Database ---
DATABASE_URL=postgresql+asyncpg://reboot:reboot@db:5432/eduation_media
POSTGRES_DB=eduation_media
POSTGRES_USER=reboot
POSTGRES_PASSWORD=reboot

# --- API ---
JWT_SECRET=replace-with-random-64-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 로컬 개발 시 web 컨테이너가 host 5273 에 매핑되므로 반드시 5273 포함
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5273,http://localhost:3000,http://localhost:4173

# --- LLM (4안: Gemini 2.5) ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIzaSy...                    # https://aistudio.google.com/app/apikey
LLM_MODEL_FAST=gemini-2.5-flash-lite
LLM_CHAT_MODEL=gemini-2.5-flash
LLM_REASONING_MODEL=gemini-2.5-flash        # 무료 티어에서 2.5-pro 는 limit=0 이므로 flash 사용
LLM_EMBEDDING_MODEL=gemini-embedding-001
LLM_EMBEDDING_DIM=768
# Hybrid mode: reasoning tier uses OpenAI, rest uses Gemini
LLM_HYBRID=true
# OpenAI fallback (선택) — hybrid mode 에서 reasoning 모델로 gpt-4o 사용
OPENAI_API_KEY=

# --- RAG ---
RAG_TOP_K=8
RAG_RERANK_TOP_K=4
RAG_SIMILARITY_THRESHOLD=0.7
RAG_GROUNDING_THRESHOLD=0.7

# --- Frontend (Next.js) ---
# 빌드 타임에 baked 되므로 docker-compose.yml 의 web.build.args 로도 전달되어야 한다.
NEXT_PUBLIC_API_URL=http://localhost:8002
